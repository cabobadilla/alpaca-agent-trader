# ==============================================================
# Alpaca Agent Trader — Environment Configuration Template
# ALPC-002: Environment Configuration Template
#
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
# ==============================================================

# --------------------------------------------------------------
# AI Provider Keys
# --------------------------------------------------------------

# Used by: agent-a, agent-c (Claude Sonnet)
ANTHROPIC_API_KEY=

# Used by: agent-b (GPT-4o-mini)
OPENAI_API_KEY=

# --------------------------------------------------------------
# Resend Email (approval-bridge)
# --------------------------------------------------------------

# Resend.com API key for outbound email
RESEND_API_KEY=

# The "From" address for approval notification emails
RESEND_FROM_EMAIL=

# The recipient address for approval notification emails
RESEND_TO_EMAIL=

# --------------------------------------------------------------
# Service URLs (agent-c)
# --------------------------------------------------------------

# Base URL for the myAlpaca Node.js service (Alpaca connector)
MYALPACA_BASE_URL=http://myalpaca:3001

# Base URL for the approval-bridge FastAPI service
APPROVAL_BRIDGE_URL=http://approval-bridge:8080

# How many minutes agent-c waits for human approval before aborting
APPROVAL_TIMEOUT_MINUTES=120

# --------------------------------------------------------------
# Cron Schedules
# --------------------------------------------------------------

# agent-a schedule: every Monday at 6:00 AM (cron expression)
AGENT_A_CRON="0 6 * * 1"

# agent-b schedule: every Monday at 6:00 AM (cron expression)
AGENT_B_CRON="0 6 * * 1"

# agent-c schedule: Monday–Friday at 9:00 AM (cron expression)
AGENT_C_CRON="0 9 * * 1-5"

# --------------------------------------------------------------
# Global Settings (all containers)
# --------------------------------------------------------------

# IANA timezone applied to all containers
TZ=America/New_York

# Python log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# --------------------------------------------------------------
# Volume Mount Paths (must match docker-compose.yml mounts)
# --------------------------------------------------------------

# Where research strategy markdown files are stored
STRATEGIES_DIR=/data/strategies

# Where generated trade plan JSON files are stored
TRADEPLANS_DIR=/data/tradeplans

# Where approval decision JSON files are stored
APPROVALS_DIR=/data/approvals
