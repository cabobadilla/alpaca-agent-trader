# ==============================================================
# Alpaca Agent Trader — .gitignore
# ALPC-002
# ==============================================================

# Local environment secrets — NEVER commit
.env

# Generated data files (runtime artifacts)
data/strategies/*.md
data/tradeplans/*.json
data/approvals/*.json

# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
*.log
logs/

# Node / JS (myalpaca reference)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS artifacts
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.iml

# Docker build cache
.dockerignore
